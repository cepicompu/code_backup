<odoo>
    <data>

        <record id="ec_pos_payment_method_form" model="ir.ui.view">
            <field name="name">ec.pos.payment.method.form</field>
            <field name="model">pos.payment.method</field>
            <field name="inherit_id" ref="point_of_sale.pos_payment_method_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='company_id']" position="after">
                    <field name='credit_card_information'/>
                </xpath>
            </field>
        </record>


        <record id="ec_pos_payment_form" model="ir.ui.view">
            <field name="name">ec.pos.payment.form</field>
            <field name="model">pos.payment</field>
            <field name="inherit_id" ref="point_of_sale.view_pos_payment_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='payment_method_id']" position="after">
                    <field name='credit_card_information' invisible="1"/>
                    <field name='type_net' />
                    <field name="credit_card_authorization" attrs="{'invisible': [('credit_card_information', '!=', True)]}"/>
                    <field name="credit_card_lote" attrs="{'invisible': [('credit_card_information', '!=', True)]}"/>
                    <field name="credit_card_reference" attrs="{'invisible': [('credit_card_information', '!=', True)]}"/>
                    <field name="state_conciliation_tc" readonly="1"/>
                </xpath>
            </field>
        </record>

        <record id="ec_view_pos_payment_search_qs" model="ir.ui.view">
            <field name="name">ec.view.pos.payment.search.qs</field>
            <field name="model">pos.payment</field>
            <field name="inherit_id" ref="point_of_sale.view_pos_payment_search"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position="after">
                    <filter string="Conciliados" name="conciliated" domain="[('state_conciliation_tc', '=', 'conciliated')]"/>
                    <filter string="No Conciliados" name="not_conciliate" domain="[('state_conciliation_tc', '!=', 'conciliated')]"/>
                </xpath>
                <xpath expr="//filter[@name='group_by_payment_method']" position="after">
                    <filter name="group_by_state_conciliation_tc" string="Estado Regularizacion TC" domain="[]"  context="{'group_by':'state_conciliation_tc'}"/>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
