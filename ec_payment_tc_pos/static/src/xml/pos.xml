<templates id="template" xml:space="preserve">

	<t t-name="CreditCardPaymentScreenPaymentLines" t-inherit="point_of_sale.PaymentScreenPaymentLines" t-inherit-mode="extension"
	   owl="1">
        <xpath expr="//div/t/t[1]/div/div[hasclass('payment-name')]" position="before">
			<t t-if="line.payment_method.credit_card_information">
				<div class="bank-button" t-on-click="() => this.trigger('credit-card', { cid: line.cid })">
					<i class="fa fa-bank" style="font-size:25px;margin-top:14px;"/>
					<br/>
					<span>C-POS</span>
				</div>
			</t>
        </xpath>
    </t>

