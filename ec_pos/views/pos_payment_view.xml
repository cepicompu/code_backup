<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <record id="ec_view_pos_payment_tree" model="ir.ui.view">
            <field name="name">ec.view.pos.payment.tree</field>
            <field name="model">pos.payment</field>
            <field name="inherit_id" ref="point_of_sale.view_pos_payment_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='payment_date']" position="after">
                    <field name="date"/>
                </xpath>
                <xpath expr="//field[@name='payment_date']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
            </field>
        </record>

        <record id="ec_view_pos_payment_form" model="ir.ui.view">
            <field name="name">ec.view.pos.payment.form</field>
            <field name="model">pos.payment</field>
            <field name="inherit_id" ref="point_of_sale.view_pos_payment_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='amount']" position="after">
                    <field name="date"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>