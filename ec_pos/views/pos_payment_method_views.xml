<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="pos_payment_method_view_form_inherit" model="ir.ui.view">
        <field name="name">pos.payment.method.form.inherit</field>
        <field name="model">pos.payment.method</field>
        <field name="inherit_id" ref="point_of_sale.pos_payment_method_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='journal_id']" position="after">
                <field name="x_ask_reference"/>
                <field name="x_ask_lote_auth"/>
                <field name="x_surcharge_percentage"/>
                <field name="x_surcharge_product_id"/>
            </xpath>
        </field>
    </record>
</odoo>
