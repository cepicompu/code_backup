<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <record id="action_report_saledetails_xlsx" model="ir.actions.report">
        <field name="name">Sales Details Excel</field>
        <field name="model">pos.details.wizard</field>
        <field name="report_type">xlsx</field>
        <field name="report_name">ec_pos.report_saledetails_xlsx</field>
        <field name="report_file">Sales Details</field>
        <field name="print_report_name">'Sales Details'</field>
        <field name="binding_model_id" ref="point_of_sale.model_pos_details_wizard"/>
        <field name="binding_type">report</field>
    </record>

    <record id="view_pos_details_wizard_form" model="ir.ui.view">
        <field name="name">pos.details.wizard.form.ec</field>
        <field name="model">pos.details.wizard</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_details_wizard"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='end_date']" position="after">
                <field name="show_sales"/>
            </xpath>
            <xpath expr="//button[@name='generate_report']" position="after">
                <button name="generate_excel_report" string="Excel" type="object" class="btn-primary"/>
            </xpath>
        </field>
    </record>

</odoo>
