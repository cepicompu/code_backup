<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Vista de Formulario del Wizard -->
    <record id="view_wizard_report_employee_custom_form" model="ir.ui.view">
        <field name="name">wizard.report.employee.custom.form</field>
        <field name="model">wizard.report.employee.custom</field>
        <field name="arch" type="xml">
            <form string="Reporte de Empleados">
                <group>
                    <group>
                        <field name="date_start"/>
                        <field name="company_id" invisible="1"/>
                    </group>
                    <group>
                        <field name="date_end"/>
                    </group>
                </group>
                <footer>
                    <button name="print_report" string="Generar Reporte" type="object" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Acción del Wizard -->
    <record id="action_wizard_report_employee_custom" model="ir.actions.act_window">
        <field name="name">Generar Reporte de Empleados</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">wizard.report.employee.custom</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
