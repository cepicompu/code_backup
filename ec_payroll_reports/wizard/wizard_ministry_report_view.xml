<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Formulario del wizard simplificado -->
    <record id="view_wizard_ministry_report_form" model="ir.ui.view">
        <field name="name">wizard.ministry.report.form</field>
        <field name="model">wizard.ministry.report</field>
        <field name="arch" type="xml">
            <form string="Nuevo Reporte Ministerio de Trabajo">
                <group>
                    <group string="Parámetros">
                        <field name="report_type" widget="radio"/>
                        <field name="fiscalyear_config_id"
                               options="{'no_create': True, 'no_open': True}"
                               string="Año Fiscal"/>
                        <field name="company_id" invisible="1"/>
                    </group>
                    <group string="Período calculado">
                        <field name="date_start" readonly="1"/>
                        <field name="date_end" readonly="1"/>
                    </group>
                </group>
                <footer>
                    <button name="action_create_and_calculate"
                            string="Calcular Reporte"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
