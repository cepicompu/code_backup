                        <table border="0" style="width:100%;font-size: 9px!important;">
                            <tbody>
                                <tr>
                                    <td style="text-align:left;">TRANSACCION # <t t-esc="medianet.medianet_reference" /></td>
                                    <td style="text-align:right;">AUTORIZACION # <t t-esc="medianet.medianet_authorization" /></td>
                                </tr>
                                <tr>
                                    <td style="text-align:left;">TOTAL:</td>
                                    <td style="text-align:right;"><t t-esc="medianet.medianet_amount_total" /></td>
                                </tr>
                                <tr>
                                    <td style="text-align:left;"><t t-esc="medianet.medianet_name_card" /></td>
                                    <td style="text-align:right;"><t t-esc="medianet.medianet_number_card" /></td>
                                </tr>
                                <tr>
                                    <td style="text-align:left;"><t t-esc="medianet.medianet_date" /></td>
