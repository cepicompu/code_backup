                        </table>
                        <br/>
                        <div class="pos-receipt-center-align" style="font-size: 10px!important;">
                            <span>GUAYAQUIL - ECUADOR</span>
                        </div>
                        <br/>
                        <div class="pos-receipt-center-align" style="font-size: 10px!important;">
                                <span>- COPIA -</span>
                         </div>
                        <br/>
                        <div style="text-align:justify;font-size: 10px!important;">
                            POLITICAS DE DEVOLUCION SEGUN EL COMERCIO
                        </div>
                        <div style="font-size: 10px!important;">
                            <span><t t-esc="medianet.medianet_aid_label" /></span>
                            <br/>
                            <span>AID: <t t-esc="medianet.medianet_aid" /></span>
                            <br/>
                            <br/>
                            <span>Nombre:</span>
                        </div>
                        <br/>
                        <div class="pos-receipt-center-align">
                            <span>- COMPROBANTE -</span>
                        </div>
                    </div>
                    <!--            TERMINA MEDIANET 2-->
                </t>
            </t>
        </xpath>
    </t>
