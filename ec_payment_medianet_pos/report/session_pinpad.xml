<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="ec_paperformat_pos" model="report.paperformat">
            <field name="name">Formato POS</field>
            <field name="default" eval="True"/>
            <field name="format">A6</field>
            <field name="page_height">0</field>
            <field name="page_width">0</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">10</field>
            <field name="margin_bottom">13</field>
            <field name="margin_left">7</field>
            <field name="margin_right">7</field>
            <field name="header_line" eval="False"/>
            <field name="header_spacing">15</field>
            <field name="dpi">90</field>
        </record>

        <record id="ec_action_report_session_pinpad" model="ir.actions.report">
            <field name="name">Reporte Pinpad</field>
            <field name="model">pos.session</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">ec_payment_medianet_pos.ec_report_session_pinpad</field>
            <field name="report_file">ec_payment_medianet_pos.ec_report_session_pinpad</field>
            <!--            <field name="print_report_name">'Vehicle Report - %s' % (object.name))</field>-->
            <field name="paperformat_id" ref="ec_payment_medianet_pos.ec_paperformat_pos" />
            <field name="binding_model_id" ref="model_pos_session"/>
            <field name="binding_type">report</field>
        </record>

        <template id="ec_report_session_pinpad">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <div class="page">
                        <div class="text-center">
                            <h3>Pagos Medianet</h3>
                            <strong>Punto de Venta: <t t-esc="o.name"/>-<t t-esc="o.config_id.name"/></strong>
                            <br/>
                            <strong>Fecha de Apertura: <t t-esc="start_at"/></strong>
                            <br/>
                            <strong>Fecha de cierre: <t t-esc="stop_at"/></strong>
                            <br/>
                        </div>
                        <br/>
                        <t t-foreach="type_red" t-as="red">
                            <span><strong><t t-esc="red['type_net']"/></strong></span>
                            <br/>
                            <t t-foreach="red['grupo_tarjeta']" t-as="grupo_tarjeta">
                                <span><strong><t t-esc="grupo_tarjeta['grupo_tarjeta']"/></strong></span>
                                <br/>
                                <table class="table table-condensed" style="width:100%;border: 2px solid black;font-size:12px !important" >
                                    <thead>
                                        <tr class="text-center">
                                            <th style="border:solid 1px; border-collapse: collapse;">LOTE</th>
                                            <th style="border:solid 1px; border-collapse: collapse;">REFERENCIA</th>
                                            <th style="border:solid 1px; border-collapse: collapse;">AUTORIZACION</th>
                                            <th style="border:solid 1px; border-collapse: collapse;">MONTO</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="grupo_tarjeta['payments']" t-as="line">
                                            <tr style="border: 1px solid black;">
                                                <td style="text-align:center;"><t t-esc="line.credit_card_lote"/></td>
                                                <td style="text-align:center;"><t t-esc="line.credit_card_reference"/></td>
                                                <td style="text-align:center;"><t t-esc="line.credit_card_authorization"/></td>
                                                <td style="text-align:center;"><t t-esc="line.amount"/></td>
                                            </tr>
                                        </t>
                                        <tr class="text-center">
                                            <th style="border:solid 1px; border-collapse: collapse;">TOTAL: </th>
                                            <th colspan="3" style="border:solid 1px; border-collapse: collapse;text-align: right" ><t t-esc="grupo_tarjeta['total']"/></th>
                                        </tr>
                                    </tbody>
                                </table>
                                <br/>
                            </t>
                            <tr class="text-center">
                                <th style="border:solid 1px; border-collapse: collapse;">TOTAL RED <span><t t-esc="red['type_net']"/></span> </th>
                                <th style="border:solid 1px; border-collapse: collapse;"><t t-esc="red['total']"/></th>
                            </tr>
                            <br/>
                            <br/>
                        </t>
                        <br/>
                        <tr class="text-center">
                            <th style="border:solid 1px; border-collapse: collapse;">TOTAL GENERALIZADO: </th>
                            <th style="border:solid 1px; border-collapse: collapse;" ><t t-esc="total"/></th>
                        </tr>
                        <br/>
                    </div>
                </t>
            </t>
        </template>

    </data>
</odoo>