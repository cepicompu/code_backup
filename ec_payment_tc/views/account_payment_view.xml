<odoo>
    <data>


        <record id="ec_payment_tc_account_payment_form" model="ir.ui.view">
            <field name="name">ec.payment.tc.account.payment.form</field>
            <field name="model">account.payment</field>
            <field name="inherit_id" ref="account.view_account_payment_form"/>
            <field name="arch" type="xml">
                <field name="journal_id" position="after">
                    <field name="is_credit_card" invisible="1"/>
                    <field name="state_conciliation_tc" invisible="1"/>
                    <field name="payment_conciliation_tc" invisible="1"/>
                    <field name="lote_tc" attrs="{'invisible': [('is_credit_card', '!=', True)]}"/>
                    <field name="auth_tc" attrs="{'invisible': [('is_credit_card', '!=', True)]}"/>
                    <field name="reference_tc" attrs="{'invisible': [('is_credit_card', '!=', True)]}"/>
                </field>
                <xpath expr="//header//button[@name='action_post']" position="after">
                    <button name="action_conciate" string="Regularizar TC" type="object"
                            class="oe_highlight" invisible="1"/>
                </xpath>
            </field>
        </record>

