<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_report_differences_by_load_wizard_form" model="ir.ui.view">
            <field name="name">report.differences.by.load.wizard.form</field>
            <field name="model">report.differences.by.load.wizard</field>
            <field name="arch" type="xml">
                <form string="Reporte de Diferencias Por Carga">
                    <sheet>
                        <group col="4">
                            <field name="date_start" required="1"/>
                            <field name="date_end" required="1"/>
                        </group>
                        <group col="4">
                            <field name="all_banks"/>
                            <field name="bank_id" options="{'no_edit': True, 'no_create': True, 'no_open': True}"
                                   attrs="{'invisible':[('all_banks', '=', True)],'required':[('all_banks','=',False)]}"/>
                        </group>
                        <footer>
                            <button
                                    name="print_xls"
                                    string="Imprimir xls"
                                    type="object"
                                    class="oe_highlight"
                            />
                            <button special="cancel" string="Cancelar" class="oe_link"/>
                        </footer>
                    </sheet>

                </form>
            </field>
        </record>


        <record id="action_report_differences_by_load_wizard" model="ir.actions.act_window">
            <field name="name">Reporte de Diferencias Por Carga</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">report.differences.by.load.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>


        <menuitem id="menu_report_differences_by_load_wizard"
                  name="Reporte de Diferencias Por Carga"
                  parent="ec_sri_authorizathions.sri_reportes" sequence="40"
                  groups="ec_payment_tc.ec_differences_by_load"
                  action="action_report_differences_by_load_wizard"/>

    </data>
</odoo>


