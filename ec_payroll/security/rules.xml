<?xml version="1.0" encoding="UTF-8"?>
<odoo>
	<data noupdate="0">

		<record id="crm_rule_own_salesteam" model="ir.rule">
			<field name="name">Ver Nóminas Propias</field>
			<field ref="hr_payroll.model_hr_payslip" name="model_id" />
			<field name="domain_force">[('employee_id.user_id', 'in', user.id)]</field>
			<field name="groups" eval="[(4, ref('base.group_user'))]" />
		</record>

		<record id="crm_rule_all_salesteam" model="ir.rule">
			<field name="name">Ver todas las Nóminas</field>
			<field ref="hr_payroll.model_hr_payslip" name="model_id" />
			<field name="domain_force">[(1,'=',1)]</field>
			<field name="groups"
				eval="[(4, ref('hr_payroll.group_hr_payroll_manager')),(4, ref('hr_payroll.group_hr_payroll_user'))]" />
		</record>


	</data>
</odoo>