<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="action_report_employee_account_bank" model="ir.actions.report">
            <field name="name">Cuentas Bancarias Empleados</field>
            <field name="model">report.ec_payroll.report_employee_account_bank</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">ec_payroll.report_employee_account_bank</field>
        </record>

        <template id="report_employee_account_bank">
            <t t-call="web.html_container">
                <t t-call="web.external_layout">
                    <div class="page" style="font-size:10px">
                        <h2 class="text-center">Cuentas Bancarias Empleados</h2>
                        <br/><br/><br/>
                        <table class="table table-borderless">
                            <thead>
                                <tr>
                                    <th class="col-xs-1">Empleado</th>
                                    <th class="col-xs-1">Departamento</th>
                                    <th class="col-xs-1">Cargo</th>
                                    <th class="col-xs-1">F.Ingreso</th>
                                    <th class="col-xs-1">Forma Pago</th>
                                    <th class="col-xs-1">Tipo Cuenta</th>
                                    <th class="col-xs-1">#Cuenta</th>
                                    <th class="col-xs-1">Banco</th>
                                </tr>
                            </thead>
                            <tbody style="border-bottom: 1px solid;margin-bottom:9px">
                                <tr class="text-center" t-foreach="vals" t-as='l'>
                                    <td><t t-esc="l.employee_id.name" /></td>
                                    <td><t t-esc="l.department_id.name" /></td>
                                    <td><t t-esc="l.job_id.name" /></td>
                                    <td><t t-esc="l.date_start" /></td>
                                    <td><t t-esc="l.employee_id.payment_method" /></td>
                                      <td><t t-if="l.employee_id.bank_account_id.type_account=='savings'">
                                            <span>AHORRO</span>
                                        </t>
                                        <t t-if="l.employee_id.bank_account_id.type_account=='current'">
                                            <span>CORRIENTE</span>
                                        </t>
                                        <t t-if="l.employee_id.bank_account_id.type_account=='vitual'">
                                            <span>VIRTUAL</span>
                                        </t>

                                    </td>     
                                    <td><t t-esc="l.employee_id.bank_account_id.acc_number" /></td>
                                    <td><t t-esc="l.employee_id.bank_account_id.bank_id.name" /></td>


                                 
                                </tr>
                            </tbody>

                        </table>

                    </div>
                </t>
            </t>
        </template>

    </data>

</odoo>
