<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="action_report_salary_history" model="ir.actions.report">
            <field name="name">Reporte de Incrementos Salariales</field>
            <field name="model">report.ec_payroll.report_salary_history</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">ec_payroll.report_salary_history</field>
        </record>

        <template id="report_salary_history">
            <t t-call="web.html_container">
                <t t-call="web.external_layout">
                    <div class="page" style="font-size:10px">
                        <h2 class="text-center">Reporte de Incrementos Salariales</h2>
                        <br/><br/><br/>
                        <table class="table table-borderless">
                            <thead>
                                <tr>
                                    <th class="col-xs-1">Empleado</th>
                                    <th class="col-xs-1">Departamento</th>
                                    <th class="col-xs-1">Cargo</th>
                                    <th class="col-xs-1">F.Ingreso</th>
                                    <th class="col-xs-1">F.Incremento</th>
                                    <th class="col-xs-1">Sueldo</th>
                                
                                    
                                </tr>
                            </thead>
                            <tbody style="border-bottom: 1px solid;margin-bottom:9px">
                                <tr class="text-center" t-foreach="vals" t-as='l'>
                                    <td><t t-esc="l['contract_id'].employee_id.name" /></td>
                                    <td><t t-esc="l['contract_id'].department_id.name" /></td>
                                    <td><t t-esc="l['contract_id'].job_id.name" /></td>
                                    <td><t t-esc="l['contract_id'].date_start" /></td>
                                    <td><t t-esc="l['date_increment']" /></td>
                                    <td><t t-esc="l['amount_increment']" /></td>

                                 
                                </tr>
                            </tbody>

                        </table>

                    </div>
                </t>
            </t>
        </template>

    </data>

</odoo>
