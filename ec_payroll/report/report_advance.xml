<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="action_report_advance" model="ir.actions.report">
            <field name="name">Reporte de Anticipos</field>
            <field name="model">report.ec_payroll.report_advance</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">ec_payroll.report_advance</field>
        </record>

        <template id="report_advance">
            <t t-call="web.html_container">
                <t t-call="web.external_layout">
                    <div class="page" style="font-size:10px">
                        <h3 class="text-center">REPORTE DE ANTICIPOS DE</h3>
                        <h3 class="text-center" t-esc="advance_type"></h3>
                        <t t-set="currency" t-value="currency_id"/>
                        <br/><br/>
                        <table class="table table-borderless">
                            <thead>
                                <tr>
                                    <th colspan="2" style="background-color: #0F1570; color: white" class="col-xs-1 text-left">Periodo</th>
                                    <th class="col-xs-1 text-left"><t t-esc="period" /></th>
                                    <th colspan="2" style="background-color: #0F1570; color: white" class="col-xs-1 text-left">Desde</th>
                                    <th colspan="2" class="col-xs-1 text-left"><t t-esc="date_start" /></th>
                                    <th colspan="2"  style="background-color: #0F1570; color: white" class="col-xs-1 text-left">Hasta</th>
                                    <th colspan="3" class="col-xs-1 text-left"><t t-esc="date_end" /></th>

                                </tr>
                                 <tr>
                                    <th style="background-color: #0F1570; color: white" class="col-xs-1 text-left">Empleado</th>
                                    <th style="background-color: #0F1570; color: white" class="col-xs-1 text-left">Identificación</th>
                                    <th style="background-color: #0F1570; color: white" class="col-xs-1 text-left">Clasificación</th>
                                    <th style="background-color: #0F1570; color: white" class="col-xs-1 text-left">Sede</th>
                                    <th style="background-color: #0F1570; color: white" class="col-xs-1 text-left">Banco</th>
                                    <th style="background-color: #0F1570; color: white" class="col-xs-1 text-left">#Cuenta</th>
                                    <th style="background-color: #0F1570; color: white" class="col-xs-1 text-left">Fecha de Solicitud</th>
                                    <th style="background-color: #0F1570; color: white" class="col-xs-1 text-left">Fecha de Pago</th>
                                    <th style="background-color: #0F1570; color: white" class="col-xs-1 text-left">Sueldo Contrato</th>
                                    <th style="background-color: #0F1570; color: white" class="col-xs-1 text-left">Porcentaje</th>
                                    <th style="background-color: #0F1570; color: white" class="col-xs-1 text-left">Monto de Anticipo</th>
                                    <th style="background-color: #0F1570; color: white" class="col-xs-1 text-left">Observación</th>

                                </tr>
                            </thead>
                            <tbody style="border-bottom: 1px solid;margin-bottom:9px">
                                <tr class="text-left" t-foreach="vals" t-as='l'>
                                    <td><t t-esc="l['employee']" /></td>
                                    <td><t t-esc="l['identification']" /></td>
                                    <td><t t-esc="l['campus']" /></td>
                                    <td><t t-esc="l['bank']" /></td>
                                    <td><t t-esc="l['bank_number']" /></td>
                                    <td><t t-esc="l['request_date']" /></td>
                                    <td><t t-esc="l['payment_date']" /></td>
                                    <td><t t-esc="l['amount_base']" t-options='{"widget": "monetary", "display_currency": currency}'/></td>
                                    <td><t t-esc="l['percent']" /></td>
                                    <td><t t-esc="l['amount']" t-options='{"widget": "monetary", "display_currency": currency}'/></td>
                                    <td><t t-esc="l['observation']" /></td>
                                </tr>
                            </tbody>
                             <tfoot>
                                <tr>
                                    <th colspan="8" style="background-color: #0F1570; color: white" class="col-xs-1">TOTALES</th>
                                    <th colspan="2" t-esc="total_base"  t-options='{"widget": "monetary", "display_currency": currency}'></th>
                                    <th colspan="2" t-esc="total_advance"  t-options='{"widget": "monetary", "display_currency": currency}'></th>
                                </tr>
                            </tfoot>

                        </table>

                    </div>
                </t>
            </t>
        </template>

    </data>

</odoo>
