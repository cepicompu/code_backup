<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="action_report_other_inputs" model="ir.actions.report">
            <field name="name">Reporte de Otros Ingresos</field>
            <field name="model">report.ec_payroll.report_other_inputs</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">ec_payroll.report_other_inputs</field>
        </record>

        <template id="report_other_inputs">
            <t t-call="web.html_container">
                <t t-call="web.external_layout">
                    <div class="page" style="font-size:10px">
                        <h2 class="text-center">Reporte de Otros Ingreoss</h2>
                        <br/><br/><br/>
                        <table class="table table-borderless">
                            <thead>
                                <tr>
                                    <th class="col-xs-1">Empleado</th>
                                    <th class="col-xs-1">Departamento</th>
                                    <th class="col-xs-1">Cargo</th>
                                    <th class="col-xs-1">F.Ini</th>
                                    <th class="col-xs-1">F.Fin</th>
                                    <th class="col-xs-1">OIngreso</th>
                                    <th class="col-xs-1">Monto</th>
                                </tr>
                            </thead>
                            <tbody style="border-bottom: 1px solid;margin-bottom:9px">
                                <tr class="text-center" t-foreach="vals" t-as='l'>
                                    <td><t t-esc="l.employee_id.name" /></td>
                                    <td><t t-esc="l.contract_id.department_id.name" /></td>
                                    <td><t t-esc="l.contract_id.job_id.name" /></td>
                                    <td><t t-esc="l.date_from" /></td>
                                    <td><t t-esc="l.date_to" /></td>
                                    <td><t t-esc="l.salary_rule_id.name" /></td>
                                    <td class="text-right"><t t-esc="l.total" /></td>


                                 
                                </tr>
                            </tbody>

                        </table>

                    </div>
                </t>
            </t>
        </template>

    </data>

</odoo>
