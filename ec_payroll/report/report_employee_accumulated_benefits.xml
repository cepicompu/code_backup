                                <tr>
                                    <th class="col-xs-1"></th>
                                    <th class="col-xs-1"></th>
                                    <th class="col-xs-1"></th>
                                    <th class="col-xs-1"></th>
                                    <th colspan="2" class="col-xs-1">Diciembre</th>
                                    <th  colspan="2" class="col-xs-1">Enero</th>
                                    <th colspan="2"  class="col-xs-1">Febrero</th>
                                    <th colspan="2"  class="col-xs-1">Marzo</th>
                                    <th  colspan="2" class="col-xs-1">Abril</th>
                                    <th  colspan="2" class="col-xs-1">Mayo</th>
                                    <th  colspan="2" class="col-xs-1">Junio</th>
                                    <th  colspan="2" class="col-xs-1">Julio</th>
                                    <th  colspan="2" class="col-xs-1">Agosto</th>
                                    <th  colspan="2" class="col-xs-1">Septiembre</th>
                                    <th colspan="2"  class="col-xs-1">Octubre</th>
                                    <th  colspan="2" class="col-xs-1">Noviembre</th>
                                    <th  colspan="2" class="col-xs-1">Total Anual</th>
                                    <th class="col-xs-1"></th>
                                    <th class="col-xs-1"></th>
                                </tr>
                                <tr>
                                    <th class="col-xs-1">Empleado</th>
                                    <th class="col-xs-1">Identificación</th>
                                    <th class="col-xs-1">Clasificación</th>
                                    <th class="col-xs-1">Departamento</th>
                                    <th class="col-xs-1">Monto</th>
                                    <th class="col-xs-1">Días</th>
                                    <th class="col-xs-1">Monto</th>
                                    <th class="col-xs-1">Días</th>
                                    <th class="col-xs-1">Monto</th>
                                    <th class="col-xs-1">Días</th>
                                    <th class="col-xs-1">Monto</th>
                                    <th class="col-xs-1">Días</th>
