                                    <td><t t-esc="l['total_days']" /></td>
                                    <td><t t-esc="l['anticipo']" /></td>
                                    <td><t t-esc="l['liquido']" /></td>

                                </tr>
                            </tbody>
                             <tfoot>
                                <tr>
                                    <th colspan="4" class="col-xs-1">TOTALES</th>
                                    <th colspan="2" t-esc="total_dic"  t-options='{"widget": "monetary", "display_currency": currency}'></th>
