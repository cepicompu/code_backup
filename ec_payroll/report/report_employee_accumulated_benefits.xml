                                    <th t-esc="total_liq"  t-options='{"widget": "monetary", "display_currency": currency}'></th>
                                </tr>
                            </tfoot>

                        </table>
                        </t>
                        <t t-if="d_type != 'fourt'">
                            <table class="table table-borderless">
                            <thead>
                                <tr>
                                    <th class="col-xs-1">Empleado</th>
                                    <th class="col-xs-1">Identificación</th>
                                    <th class="col-xs-1">Clasificación</th>
                                    <th class="col-xs-1">Departamento</th>
                                    <th class="col-xs-1">Diciembre</th>
