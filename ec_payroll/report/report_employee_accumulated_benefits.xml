                                    <th class="col-xs-1">Anticipos</th>
                                    <th class="col-xs-1">Líquido</th>
                                </tr>
                            </thead>
                            <tbody style="border-bottom: 1px solid;margin-bottom:9px">
                                <tr class="text-center" t-foreach="vals" t-as='l'>
                                    <td><t t-esc="l['employee']" /></td>
                                    <td><t t-esc="l['identification']" /></td>
                                    <td><t t-esc="l['department']" /></td>
                                    <td><t t-esc="l['dic']" /></td>
                                    <td><t t-esc="l['daydic']" /></td>
                                    <td><t t-esc="l['ene']" /></td>
                                    <td><t t-esc="l['dayene']" /></td>
                                    <td><t t-esc="l['feb']" /></td>
                                    <td><t t-esc="l['dayfeb']" /></td>
                                    <td><t t-esc="l['marz']" /></td>
                                    <td><t t-esc="l['daymarz']" /></td>
                                    <td><t t-esc="l['abr']" /></td>
                                    <td><t t-esc="l['dayabr']" /></td>
                                    <td><t t-esc="l['may']" /></td>
                                    <td><t t-esc="l['daymay']" /></td>
                                    <td><t t-esc="l['jun']" /></td>
                                    <td><t t-esc="l['dayjun']" /></td>
                                    <td><t t-esc="l['jul']" /></td>
                                    <td><t t-esc="l['dayjul']" /></td>
