<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="paperformat_account_standard" model="report.paperformat">
            <field name="name">A4 Landscape Account</field>
            <field name="default" eval="True"/>
            <field name="format">custom</field>
            <field name="page_height">0</field>
            <field name="page_width">0</field>
            <field name="orientation">Landscape</field>
            <field name="margin_top">40</field>
            <field name="margin_bottom">23</field>
            <field name="margin_left">5</field>
            <field name="margin_right">5</field>
            <field name="header_line" eval="False"/>
            <field name="header_spacing">35</field>
            <field name="dpi">90</field>
        </record>


        <record id="action_report_employee_accumulated_benefits" model="ir.actions.report">
            <field name="name">Reporte de Acumulaciones de Décimos</field>
            <field name="model">report.ec_payroll.report_employee_accumulated_benefits</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">ec_payroll.report_employee_accumulated_benefits</field>
            <field name="paperformat_id" ref="paperformat_account_standard"/>
        </record>

        <template id="report_employee_accumulated_benefits">
            <t t-call="web.html_container">
                <t t-call="web.external_layout">
                    <div>
                        <h6 class="text-right" t-esc="current_date"/>
                    </div>
                    <div class="page" style="font-size:10px">
                        <t t-if="d_type == 'thirt'">
                            <h2 class="text-center">Reporte de Acumulaciones de Décimo Tercero</h2>
                        </t>
                        <t t-if="d_type == 'fourt'">
                            <h2 class="text-center">Reporte de Acumulaciones de Décimo Cuarto</h2>
                        </t>
                        <t t-if="d_type == 'reserve_funds'">
                            <h2 class="text-center">Reporte de Acumulaciones de Fondos de Reserva</h2>
                        </t>
                        <h2 class="text-center">Periodo 1/12/<t t-esc="period_year_ant" /> - 31/11/<t t-esc="period_year" /></h2>
                        <br/><br/><t t-set="currency" t-value="currency_id"/>
