                            </thead>
                            <tbody style="border-bottom: 1px solid;margin-bottom:9px">
                                <tr class="text-center" t-foreach="vals" t-as='l'>
                                    <td><t t-esc="l['employee']" /></td>
                                    <td><t t-esc="l['identification']" /></td>
                                    <td><t t-esc="l['department']" /></td>
                                    <td><t t-esc="l['dic']" /></td>
                                    <td><t t-esc="l['ene']" /></td>
                                    <td><t t-esc="l['feb']" /></td>
                                    <td><t t-esc="l['marz']" /></td>
                                    <td><t t-esc="l['abr']" /></td>
                                    <td><t t-esc="l['may']" /></td>
                                    <td><t t-esc="l['jun']" /></td>
                                    <td><t t-esc="l['jul']" /></td>
                                    <td><t t-esc="l['ago']" /></td>
                                    <td><t t-esc="l['sep']" /></td>
                                    <td><t t-esc="l['oct']" /></td>
                                    <td><t t-esc="l['nov']" /></td>
                                    <td><t t-esc="l['total_year']" /></td>
                                    <td><t t-esc="l['anticipo']" /></td>
                                    <td><t t-esc="l['liquido']" /></td>

                                </tr>
                            </tbody>
