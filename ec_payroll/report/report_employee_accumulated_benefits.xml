                                    <th t-esc="total_ago"  t-options='{"widget": "monetary", "display_currency": currency}'></th>
                                    <th t-esc="total_sep"  t-options='{"widget": "monetary", "display_currency": currency}'></th>
                                    <th t-esc="total_oct"  t-options='{"widget": "monetary", "display_currency": currency}'></th>
                                    <th t-esc="total_nov"  t-options='{"widget": "monetary", "display_currency": currency}'></th>
                                    <th t-esc="total_val"  t-options='{"widget": "monetary", "display_currency": currency}'></th>
                                    <th t-esc="total_ant"  t-options='{"widget": "monetary", "display_currency": currency}'></th>
                                    <th t-esc="total_liq"  t-options='{"widget": "monetary", "display_currency": currency}'></th>
                                </tr>
                            </tfoot>

                        </table>
                        </t>

                    </div>
                </t>
            </t>
        </template>

    </data>

</odoo>
