<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="action_report_deduction" model="ir.actions.report">
            <field name="name">Reporte de Deducciones</field>
            <field name="model">report.ec_payroll.report_deduction</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">ec_payroll.report_deduction</field>
        </record>

        <template id="report_deduction">
            <t t-call="web.html_container">
                <t t-call="web.external_layout">
                    <div class="page" style="font-size:10px">
                        <h2 class="text-center">Reporte de Deducciones</h2>
                        <t t-set="currency" t-value="currency_id"/>
                        <br/><br/><br/>
                        <table class="table table-borderless">
                            <thead>
                                <tr>
                                    <th style="background-color: #0F1570; color: white" class="col-xs-1 text-left">Empleado</th>
                                    <th style="background-color: #0F1570; color: white" class="col-xs-1 text-left">Identificación</th>
                                    <th style="background-color: #0F1570; color: white" class="col-xs-1 text-left">Clasificación</th>
                                    <th style="background-color: #0F1570; color: white" class="col-xs-1 text-left">Fecha</th>
                                    <th style="background-color: #0F1570; color: white" class="col-xs-1 text-left">Motivo</th>
                                    <th style="background-color: #0F1570; color: white" class="col-xs-1 text-left">Observación</th>
                                    <th style="background-color: #0F1570; color: white" class="col-xs-1 text-left">Monto</th>
                                </tr>
                            </thead>
                            <tbody style="border-bottom: 1px solid;margin-bottom:9px">
                                <tr class="text-left" t-foreach="vals" t-as='l'>
                                    <td><t t-esc="l['employee']" /></td>
                                    <td><t t-esc="l['identification']" /></td>
                                    <td><t t-esc="l['date']" /></td>
                                    <td><t t-esc="l['motive']" /></td>
                                    <td><t t-esc="l['observation']" /></td>
                                    <td><t t-esc="l['amount']" t-options='{"widget": "monetary", "display_currency": currency}'/></td>
                                </tr>
                            </tbody>
                            <tfoot>
                                <tr>
                                    <th colspan="6" style="background-color: #0F1570; color: white" class="col-xs-1">TOTALES</th>
                                    <th t-esc="total"  t-options='{"widget": "monetary", "display_currency": currency}'></th>
                                </tr>
                            </tfoot>

                        </table>

                    </div>
                </t>
            </t>
        </template>

    </data>

</odoo>
