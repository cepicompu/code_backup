<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="ec_payroll_wizard_report_vacations_form" model="ir.ui.view">
            <field name="name">report.vacations.wizard.form</field>
            <field name="model">report.vacations.wizard</field>
            <field name="arch" type="xml">
                <form string="Reporte de Vacaciones">º
                    <footer>
                        <button type="object" name="print_pdf_report" string="PDF"
                                class="btn-primary"/>
                        <button type="object" name="print_xls_report" string="XLS"
                                class="btn-primary"/>
                        <button string="Cancelar" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>


        <record id="action_wiz_report_vacations" model="ir.actions.act_window">
            <field name="name">Reporte de Vacaciones</field>
            <field name="res_model">report.vacations.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <menuitem
                id="menu_report_vacations"
                name="Reporte de Vacaciones"
                parent="hr_payroll.menu_hr_payroll_report"
                action="ec_payroll.action_wiz_report_vacations"
                sequence="11"/>
    </data>
</odoo>