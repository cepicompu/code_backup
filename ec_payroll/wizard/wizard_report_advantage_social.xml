<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="ec_payroll_wizard_report_advantage_social_form" model="ir.ui.view">
            <field name="name">report.advantage.social.wizard.form</field>
            <field name="model">report.advantage.social.wizard</field>
            <field name="arch" type="xml">
                <form string="Reporte de Beneficios Sociales">
                    <group col="2">
                        <field name="not_range"  string="Sin rango de fecha"/>
                        <field name="start_date"  attrs="{'readonly':[('not_range','=',True)]}"/>
                        <field name="end_date"  attrs="{'readonly':[('not_range','=',True)]}"/>
                    </group>
                    <footer>
                        <button type="object" name="print_pdf_report" string="PDF"
                                class="btn-primary"/>
                        <button type="object" name="print_xls_report" string="XLS"
                                class="btn-primary"/>
                        <button string="Cancelar" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>


        <record id="action_wiz_report_advantage_social" model="ir.actions.act_window">
            <field name="name">Reporte de Beneficios Sociales</field>
            <field name="res_model">report.advantage.social.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

<!--        <menuitem-->
