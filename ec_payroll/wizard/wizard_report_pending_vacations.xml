<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="ec_payroll_wizard_report_pending_vacations_form" model="ir.ui.view">
            <field name="name">report.pending.vacations.wizard.form</field>
            <field name="model">report.pending.vacations.wizard</field>
            <field name="arch" type="xml">
                <form string="Reporte de Vacaciones Pendientes">
                    <group col="2">
                        <field name="date_evaluated"/>
                        <field name="all_employees" />
                        <field name="employee_id" attrs="{'readonly':[('all_employees','=',True)]}" />
                        
                    </group>
                    <footer>
                        <button type="object" name="print_pdf_report" string="PDF"
                                class="btn-primary"/>
                        <button type="object" name="print_xls_report" string="XLS"
                                class="btn-primary"/>
                        <button string="Cancelar" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>


        <record id="action_wiz_report_pending_vacations" model="ir.actions.act_window">
            <field name="name">Reporte de Vacaciones Pendientes</field>
            <field name="res_model">report.pending.vacations.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <menuitem
                id="menu_report_pending_vacations"
                name="Reporte de Vacaciones Pendientes"
                parent="hr_payroll.menu_hr_payroll_report"
                action="ec_payroll.action_wiz_report_pending_vacations"
                sequence="19"/>
    </data>
</odoo>