<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="ec_payroll_wizard_report_thenths_form" model="ir.ui.view">
            <field name="name">report.thenths.wizard.form</field>
            <field name="model">report.thenths.wizard</field>
            <field name="arch" type="xml">
                <form string="Reporte de Décimos">
                    <group col="2">
                        <field name="anio" />
                        <field name="report_type"/>
                        
                    </group>
                    <footer>
                        <button type="object" name="print_pdf_report" string="PDF"
                                class="btn-primary"/>
                        <button type="object" name="print_xls_report" string="XLS"
                                class="btn-primary"/>
                        <button string="Cancelar" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>


        <record id="action_wiz_report_thenths" model="ir.actions.act_window">
            <field name="name">Reporte Provisión de Décimos</field>
            <field name="res_model">report.thenths.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <menuitem
                id="menu_report_thenths"
                name="Reporte de Provisión de Décimos"
                parent="hr_payroll.menu_hr_payroll_report"
                action="ec_payroll.action_wiz_report_thenths"
                sequence="50"/>
    </data>
</odoo>