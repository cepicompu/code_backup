<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="ec_payroll_wizard_report_employee_account_bank_form" model="ir.ui.view">
            <field name="name">report.employee.account.bank.wizard.form</field>
            <field name="model">report.employee.account.bank.wizard</field>
            <field name="arch" type="xml">
                <form string="Cuentas Bancarias Empleados">
                    <group col="2">
                      <field name="start_date"/>
                      <field name="end_date"/>
                    </group>
                    <footer>
                        <button type="object" name="print_pdf_report" string="PDF"
                                class="btn-primary"/>
                        <button type="object" name="print_xls_report" string="XLS"
                                class="btn-primary"/>
                        <button string="Cancelar" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>


        <record id="action_wiz_report_employee_account_bank" model="ir.actions.act_window">
            <field name="name">Cuentas Bancarias Empleados</field>
            <field name="res_model">report.employee.account.bank.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <menuitem
                id="menu_report_account_bank"
                name="Cuentas Bancarias Empleados"
                parent="hr_payroll.menu_hr_payroll_report"
                action="ec_payroll.action_wiz_report_employee_account_bank"
                sequence="19"/>
    </data>
</odoo>