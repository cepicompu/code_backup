<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="ec_payroll_wizard_report_salary_history_form" model="ir.ui.view">
            <field name="name">report.salary.history.wizard.form</field>
            <field name="model">report.salary.history.wizard</field>
            <field name="arch" type="xml">
                <form string="Reporte de Incrementos Salariales">
                    <group>
                        <group>
                            <field name="all_records"/>

                        </group>

                    </group>
                    <group col="3">
                        <group>
                            <field name="employee_id" attrs="{'readonly':[('all_records','=',True)]}"/>
                            
                        </group>
                      
                    </group>
                    <footer>
                        <button type="object" name="print_pdf_report" string="PDF"
                                class="btn-primary"/>
                        <button type="object" name="print_xls_report" string="XLS"
                                class="btn-primary"/>
                        <button string="Cancelar" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>


        <record id="action_wiz_report_salary_history" model="ir.actions.act_window">
            <field name="name">Reporte de Incrementos Salariales</field>
            <field name="res_model">report.salary.history.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <menuitem
                id="menu_report_salary_history"
                name="Reporte de Incrementos Salariales"
                parent="hr_payroll.menu_hr_payroll_report"
                action="ec_payroll.action_wiz_report_salary_history"
                sequence="19"/>
    </data>
</odoo>