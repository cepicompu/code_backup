<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="ec_payroll_wizard_report_income_tax_form" model="ir.ui.view">
            <field name="name">report.income.tax.wizard.form</field>
            <field name="model">report.income.tax.wizard</field>
            <field name="arch" type="xml">
                <form string="Reporte de Impuesto a la Renta">
                    <group col="2">
                        <field name="salary_rule_id"/>
                        <field name="report_type"/>
                        <field name="start_date"  />
                        <field name="end_date"  />
                    </group>
                    <footer>
                        <button type="object" name="print_pdf_report" string="PDF"
                                class="btn-primary"/>
                        <button type="object" name="print_xls_report" string="XLS"
                                class="btn-primary"/>
                        <button string="Cancelar" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>


        <record id="action_wiz_report_income_tax" model="ir.actions.act_window">
            <field name="name">Reporte de Impuesto a la Renta</field>
            <field name="res_model">report.income.tax.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <menuitem
                id="menu_report_income_tax"
                name="Reporte de Impuesto a la Renta"
                parent="hr_payroll.menu_hr_payroll_report"
                action="ec_payroll.action_wiz_report_income_tax"
                sequence="50"/>
    </data>
</odoo>