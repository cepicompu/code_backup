<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="ec_payroll_wizard_report_employee_simplified_form" model="ir.ui.view">
            <field name="name">report.employee.simplified.wizard.form</field>
            <field name="model">report.employee.simplified.wizard</field>
            <field name="arch" type="xml">
                <form string="Reporte Simplificado de Empleados">
                    <group col="2">
                        <separator string="Seleccione el tipo de empleados que desea imprimir" colspan="4" />
                        <field name="selected_employee" />
                    </group>
                    <footer>
                        <button type="object" name="print_xls_report" string="Generar Excel" class="btn-primary"/>
                        <button string="Cancelar" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>


        <record id="action_wiz_report_employee_simplified" model="ir.actions.act_window">
            <field name="name">Reporte de Empleados (Excel)</field>
            <field name="res_model">report.employee.simplified.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <menuitem id="menu_report_employee_simplified" name="Reporte de Empleados (Excel)" parent="hr_payroll.menu_hr_payroll_report" action="ec_payroll.action_wiz_report_employee_simplified" sequence="23"/>
    </data>
</odoo>
