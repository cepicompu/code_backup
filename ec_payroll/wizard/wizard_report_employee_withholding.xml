<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="ec_payroll_wizard_report_employee_withholding_form" model="ir.ui.view">
            <field name="name">report.employee.withholding.wizard.form</field>
            <field name="model">report.employee.withholding.wizard</field>
            <field name="arch" type="xml">
                <form string="Reporte de Retenciones en la Fuente">
                    <group col="2">
                        <field name="date_from"  />
                        <field name="date_to"  />
                    </group>
                    <footer>
                        <button type="object" name="print_xls_report" string="XLS"
                                class="btn-primary"/>
                        <button string="Cancelar" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>


        <record id="action_wiz_report_employee_withholding" model="ir.actions.act_window">
            <field name="name">Reporte de Retenciones en la Fuente</field>
            <field name="res_model">report.employee.withholding.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <menuitem
                id="menu_report_employee_withholding"
                name="Reporte 107"
                parent="hr_payroll.menu_hr_payroll_report"
                action="ec_payroll.action_wiz_report_employee_withholding"
                sequence="50"/>
    </data>
</odoo>