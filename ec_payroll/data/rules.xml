<odoo>

    <data noupdate="1">
        <!-- Request-related subtypes for messaging / Chatter -->
        <record id="mt_request_egress_to_approve" model="mail.message.subtype">
            <field name="name">Egress Request to be approved</field>
            <field name="sequence">1</field>
            <field name="res_model">request.egress</field>
            <field name="default" eval="True"/>
            <field name="internal" eval="True"/>
            <field name="description">Egress Request to be approved</field>
        </record>

        <record id="mt_request_egress_approved" model="mail.message.subtype">
            <field name="name">Egress Request approved</field>
            <field name="res_model">request.egress</field>
            <field name="default" eval="True"/>
            <field name="description">Egress Request approved</field>
        </record>

        <record id="mt_request_egress_rejected" model="mail.message.subtype">
            <field name="name">Egress Request rejected</field>
            <field name="res_model">request.egress</field>
            <field name="default" eval="True"/>
            <field name="description">Egress Request Rejected</field>
        </record>

    </data>
</odoo>

