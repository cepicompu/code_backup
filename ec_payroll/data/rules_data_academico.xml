            <field name='condition_select'>python</field>
            <field name='condition_python'>result=worked_days.MATERNIDAD</field>
            <field name="amount_select">code</field>
             <field name="amount_python_compute">days = worked_days.MATERNIDAD.number_of_days
net=0.00

# aportable=(categories.INGR + categories.OINGR + categories.OINGSUB)/30
aportable=(contract.wage if contract.type_day=='complete' else contract.value_for_parcial)/30

net=days * (aportable*0.25)

if (categories.INGR &lt; contract.wage):
    net = aportable - categories.INGR
else:
    net=0


result= net</field>
