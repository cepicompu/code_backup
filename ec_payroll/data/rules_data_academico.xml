        <record id="hr_rule_subsidio_enfermedad" model="hr.salary.rule">
            <field name="name">Subsidio por Enfermedad</field>
            <field name="sequence" eval="120"/>
            <field name="code">SUBSENF</field>
            <field name="category_id" ref="INGR"/>
            <field name="struct_id" search="[('name', '=', 'SALARIOBU')]"/>
            <field name='condition_select'>python</field>
            <field name='condition_python'>result=worked_days.ENFERMEDAD</field>
            <field name="amount_select">code</field>
            <field name="account_debit" search="[('code','=','6101010119')]" /> 
            <field name="account_credit" search="[('code','=','2103030104')]" /> 
            <field name="amount_python_compute">
days = worked_days.ENFERMEDAD.number_of_days
net=0.00

# aportable=(categories.INGR + categories.OINGR + categories.OINGSUB)/30
aportable=(contract.wage if contract.type_day=='complete' else contract.value_for_parcial)/30

if days>=3:
    net=(3*aportable)*0.5
else:
    net=(days*aportable)*0.5
    #net+=((days-3) * aportable)*0.25

result= net</field>
        </record>
        
