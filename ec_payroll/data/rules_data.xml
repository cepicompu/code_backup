            <field name="account_credit" search="[('code','=','2103030104')]" />
            <field name="amount_python_compute">
days = worked_days.ENFERMEDAD.number_of_days


net=0.00
if contract.type_day=='complete':
    aportable= contract.wage/30
else:
    days = worked_days.ENFERMEDAD.number_of_hours/8
    aportable= contract.daily_value

