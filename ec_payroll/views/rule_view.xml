<?xml version="1.0" encoding="UTF-8"?>
<odoo>
	<data>


		<record model="ir.ui.view" id="ec_hr_salary_rule_tree_view">
			<field name="name">hr.salary.rule.form</field>
			<field name="model">hr.salary.rule</field>
			<field name="inherit_id" ref="hr_payroll.hr_salary_rule_list" />
			<field name="arch" type="xml">
				<xpath expr="//field[@name='sequence']" position="attributes">
					<attribute name="invisible">0</attribute>
					<attribute name="optional">hide</attribute>
				</xpath>
				<xpath expr="//tree" position="inside">
					<field name="sequence_for_report" optional="hide"/>
					<field name="account_debit" optional="hide"/>
					<field name="account_credit" optional="hide"/>
				</xpath>
			</field>
		</record>

		<record model="ir.ui.view" id="hr_salary_rule_form_view">
			<field name="name">hr.salary.rule.form</field>
			<field name="model">hr.salary.rule</field>
			<field name="inherit_id" ref="hr_payroll.hr_salary_rule_form" />
			<field name="arch" type="xml">
				<field name="amount_percentage_base" position="replace">
					<field name="percentage_id" widget="selection"
						   attrs="{'invisible': [('amount_select', '!=', 'percentage')], 'required': [('amount_select', '=', 'percentage')]}" />
					<field name="amount_percentage_base" nolabel="1" />
				</field>
				<field name="appears_on_payslip" position="after">
					<field name="sequence_for_report"/>
				</field>
			</field>
		</record>


		<record model="ir.ui.view" id="hr_salary_rule_account_form_view">
			<field name="name">hr.salary.rule.form</field>
			<field name="model">hr.salary.rule</field>
			<field name="inherit_id" ref="hr_payroll_account.hr_salary_rule_view_form" />
			<field name="arch" type="xml">
				<field name="not_computed_in_net" position="after">
					<field name="account_payslip"/>
					<!--					<field name="tax_code_id" />-->
					<field name="is_food" />
					<field name="no_account" />
					<field name="group_move" />
					<field name="pay_to_other" />
					<field name="partner_id"
						   attrs="{'invisible':[('pay_to_other', '=', False)], 'required': [('pay_to_other', '=', True)]}" />
					<field name="set_date_maturity_region" />
					<field name= "apply_report_ir"/>
					<field name= "sign_report" placeholder="Ingresar 1 o -1" attrs="{'required': [('apply_report_ir', '=', True)], 'readonly': [('apply_report_ir', '=', False)]}"/>
					<field name= "code_report" attrs="{'required': [('apply_report_ir', '=', True)], 'readonly': [('apply_report_ir', '=', False)]}"/>
				</field>
			</field>
		</record>
	</data>
</odoo>