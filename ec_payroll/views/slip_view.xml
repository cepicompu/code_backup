						<separator string="Ingresos"/>
							<field name="income_line_ids" colspan="4" nolabel="1">
								<tree string="Ingresos" editable="bottom" create="0" delete="0">
									<field name="name"/>
									<field name="code" readonly="1" force_save="1" optional="hide"/>
									<field name="category_id" readonly="1" force_save="1"/>
									<field name="sequence" invisible="1" readonly="1" force_save="1"/>
<!--									<field name="amount" readonly="1" force_save="1" sum="Total"/>-->
									<field name="total" readonly="1" force_save="1" sum="Total"/>
									<field name="currency_id" invisible="1"/>
								</tree>
								<form string="Línea de Ingreso">
									<group col="4">
										<field name="name"/>
										<field name="code"/>
										<field name="category_id"/>
										<field name="sequence"/>
<!--										<field name="amount"/>-->
										<field name="total"/>
										<field name="currency_id" invisible="1"/>
									</group>
								</form>
							</field>
<!--						</group>-->
<!--						<group string="Deducciones" name="deductions_group">-->
