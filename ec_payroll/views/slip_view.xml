									<field name="code" readonly="1" force_save="1" optional="hide"/>
									<field name="category_id" readonly="1" force_save="1"/>
									<field name="sequence" invisible="1" readonly="1" force_save="1"/>
<!--									<field name="amount" readonly="1" force_save="1" sum="Total"/>-->
									<field name="total" readonly="1" force_save="1" sum="Total"/>
									<field name="currency_id" invisible="1"/>
								</tree>
								<form string="Línea de Deducción">
									<group col="4">
										<field name="name"/>
										<field name="code"/>
										<field name="category_id"/>
										<field name="sequence"/>
<!--										<field name="amount"/>-->
										<field name="total"/>
										<field name="currency_id" invisible="1"/>
									</group>
								</form>
							</field>
<!--						</group>-->
						<group class="oe_subtotal_footer">
							<field name="total_ingresos" widget="monetary" class="text-right"/>
							<field name="total_deducciones" widget="monetary" class="text-right"/>
							<field name="salario_neto" widget="monetary" class="oe_subtotal_footer_separator"/>
						</group>
					</page>
				</xpath>



