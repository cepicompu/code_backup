<?xml version="1.0" encoding="UTF-8"?>
<odoo>
	<data>

		<record model="ir.ui.view" id="employee_department_historytwo">
			<field name="name">departmenthistorytwo.tree</field>
			<field name="model">department.history</field>
			<field name="inherit_id" ref="history_employee.employee_department_history"/>
			<field name="arch" type="xml" >
				<xpath expr="//tree" position="attributes">
					<attribute name="edit">0</attribute>
					<attribute name="delete">0</attribute>
					<attribute name="create">0</attribute>
				</xpath>
				<xpath expr="//field[@name='updated_date']" position="attributes">
					<attribute name="string">Fecha de cambio</attribute>
				</xpath>
				<xpath expr="//field[@name='updated_date']" position="after">
					<field name="cargo_id"/>
				</xpath>
				<xpath expr="//field[@name='updated_date']" position="before">
					<field name="departamento_id"/>
					<field name="area_id"/>
				</xpath>

				<xpath expr="//field[@name='changed_field']" position="attributes">
					<attribute name="invisible">True</attribute>
				</xpath>
				<xpath expr="//field[@name='current_value']" position="attributes">
					<attribute name="invisible">True</attribute>
				</xpath>
			</field>
		</record>

		<record model="ir.ui.view" id="employee_salary_historytwo">
			<field name="name">salaryhistorytwo.tree</field>
			<field name="model">salary.history</field>
			<field name="inherit_id" ref="history_employee.employee_salary_history"/>
			<!--            <field name="view_mode">tree</field>-->
			<field name="arch" type="xml">
				<xpath expr="//tree" position="attributes">
					<attribute name="edit">0</attribute>
					<attribute name="delete">0</attribute>
					<attribute name="create">0</attribute>
				</xpath>
				<xpath expr="//field[@name='updated_date']" position="attributes">
					<attribute name="string">Fecha de actualización</attribute>
				</xpath>
				<xpath expr="//field[@name='updated_date']" position="after">
					<field name="contrato_id"/>
					<field name="cargo_id"/>
					<field name="sueldo"/>
				</xpath>
				<xpath expr="//field[@name='current_value']" position="attributes">
					<attribute name="invisible">True</attribute>
				</xpath>
			</field>
		</record>


		<record model="ir.ui.view" id="employee_contract_historytwo">
			<field name="name">contracthistory.tree</field>
			<field name="model">contract.history</field>
			<field name="inherit_id" ref="history_employee.employee_contract_history"/>
			<!--            <field name="view_mode">tree</field>-->
			<field name="arch" type="xml">
				<xpath expr="//tree" position="attributes">
					<attribute name="editable">bottom</attribute>
					<attribute name="string">Historial de Contratos</attribute>
				</xpath>
				<xpath expr="//field[@name='updated_date']" position="attributes">
					<attribute name="string">Fecha de actualización</attribute>
				</xpath>
				<xpath expr="//field[@name='updated_date']" position="after">
					<field name="tipo_documento" required="1"/>
					<field name="observacion" required="1"/>
					<field name="contrato_id" force_save="1" readonly="1"/>
				</xpath>
				<xpath expr="//field[@name='current_value']" position="attributes">
					<attribute name="invisible">True</attribute>
				</xpath>
				<xpath expr="//field[@name='changed_field']" position="attributes">
					<attribute name="invisible">True</attribute>
				</xpath>
			</field>
		</record>


